{
  "info": {
    "_postman_id": "80e75a72-f831-4f35-9d6e-9c06c4e7b294",
    "name": "JSONCargo API",
    "description": "Complete Postman collection for the JSONCargo container and vessel tracking API. Set your API key in the included environment file before making requests.\n\nFull documentation: https://jsoncargo.com/documentation-api/",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Container Tracking",
      "item": [
        {
          "name": "Track a container",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{JSONCARGO_API_KEY}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://api.jsoncargo.com/api/v1/containers/MSCU5285725",
              "protocol": "http",
              "host": ["api", "jsoncargo", "com"],
              "path": ["api", "v1", "containers", "MSCU5285725"]
            },
            "description": "Fetch full tracking details for a container. Replace MSCU5285725 with your container number. Add ?shipping_line=MSC if the prefix is shared across carriers."
          },
          "response": []
        },
        {
          "name": "Track a container (with shipping_line)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{JSONCARGO_API_KEY}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://api.jsoncargo.com/api/v1/containers/MNBU0171007?shipping_line=MAERSK",
              "protocol": "http",
              "host": ["api", "jsoncargo", "com"],
              "path": ["api", "v1", "containers", "MNBU0171007"],
              "query": [
                {
                  "key": "shipping_line",
                  "value": "MAERSK"
                }
              ]
            },
            "description": "Use the shipping_line parameter when the container prefix is shared across multiple carriers. Valid values: MAERSK, HAPAG_LLOYD, HMM, ONE, EVERGREEN, MSC, CMA_CGM, COSCO, ZIM, YANG_MING, PIL"
          },
          "response": []
        },
        {
          "name": "Get containers from Bill of Lading",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{JSONCARGO_API_KEY}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://api.jsoncargo.com/api/v1/containers/bol/SELM60819800?shipping_line=HMM",
              "protocol": "http",
              "host": ["api", "jsoncargo", "com"],
              "path": ["api", "v1", "containers", "bol", "SELM60819800"],
              "query": [
                {
                  "key": "shipping_line",
                  "value": "HMM"
                }
              ]
            },
            "description": "Returns all container numbers linked to a bill of lading. shipping_line is always required for BOL lookups. Response includes associated_container_numbers array."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Vessel Tracking",
      "item": [
        {
          "name": "Vessel Basic",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{JSONCARGO_API_KEY}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://api.jsoncargo.com/api/v1/vessel/basic?mmsi=566093000",
              "protocol": "http",
              "host": ["api", "jsoncargo", "com"],
              "path": ["api", "v1", "vessel", "basic"],
              "query": [
                {
                  "key": "mmsi",
                  "value": "566093000"
                }
              ]
            },
            "description": "Live vessel position and navigation status. Identify the vessel by mmsi, imo, or uuid."
          },
          "response": []
        },
        {
          "name": "Vessel Pro",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{JSONCARGO_API_KEY}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://api.jsoncargo.com/api/v1/vessel/pro?mmsi=566093000",
              "protocol": "http",
              "host": ["api", "jsoncargo", "com"],
              "path": ["api", "v1", "vessel", "pro"],
              "query": [
                {
                  "key": "mmsi",
                  "value": "566093000"
                }
              ]
            },
            "description": "Extends basic tracking with departure port, current draught, ATD, and timezone data."
          },
          "response": []
        },
        {
          "name": "Vessel Bulk (MMSI and IMO)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{JSONCARGO_API_KEY}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://api.jsoncargo.com/api/v1/vessel/bulk?mmsi=710466000&imo=9457165",
              "protocol": "http",
              "host": ["api", "jsoncargo", "com"],
              "path": ["api", "v1", "vessel", "bulk"],
              "query": [
                {
                  "key": "mmsi",
                  "value": "710466000"
                },
                {
                  "key": "imo",
                  "value": "9457165"
                }
              ]
            },
            "description": "Fetch live data for up to 100 vessels in a single request. Mix and match mmsi, imo, and uuid identifiers."
          },
          "response": []
        },
        {
          "name": "Vessel Finder",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{JSONCARGO_API_KEY}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://api.jsoncargo.com/api/v1/vessel/finder?name=Aurora",
              "protocol": "http",
              "host": ["api", "jsoncargo", "com"],
              "path": ["api", "v1", "vessel", "finder"],
              "query": [
                {
                  "key": "name",
                  "value": "Aurora"
                }
              ]
            },
            "description": "Search static vessel registry by name, type, flag, tonnage, dimensions, or year built. Add &fuzzy=1 for approximate name matching."
          },
          "response": []
        },
        {
          "name": "Vessel Specs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{JSONCARGO_API_KEY}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://api.jsoncargo.com/api/v1/vessel/specs?mmsi=566093000",
              "protocol": "http",
              "host": ["api", "jsoncargo", "com"],
              "path": ["api", "v1", "vessel", "specs"],
              "query": [
                {
                  "key": "mmsi",
                  "value": "566093000"
                }
              ]
            },
            "description": "Static registry data for a specific vessel: dimensions, tonnage, TEU capacity, year built, and more."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Ports and Terminals",
      "item": [
        {
          "name": "Port Finder",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{JSONCARGO_API_KEY}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://api.jsoncargo.com/api/v1/port/find?country_iso=GB",
              "protocol": "http",
              "host": ["api", "jsoncargo", "com"],
              "path": ["api", "v1", "port", "find"],
              "query": [
                {
                  "key": "country_iso",
                  "value": "GB"
                }
              ]
            },
            "description": "Search ports by name, country, type, or lat/lon with radius. Supports fuzzy=1 for approximate name matching."
          },
          "response": []
        },
        {
          "name": "Terminal Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{JSONCARGO_API_KEY}}"
              }
            ],
            "url": {
              "raw": "http://api.jsoncargo.com/api/v1/terminal?unlocode=AEJEA&unlocode=BDMUN",
              "protocol": "http",
              "host": ["api", "jsoncargo", "com"],
              "path": ["api", "v1", "terminal"],
              "query": [
                {
                  "key": "unlocode",
                  "value": "AEJEA"
                },
                {
                  "key": "unlocode",
                  "value": "BDMUN"
                }
              ]
            },
            "description": "Returns terminal details for one or more UN/LOCODEs. Pass multiple unlocode params to query several terminals at once."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Utilities",
      "item": [
        {
          "name": "Prefix Lookup",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{JSONCARGO_API_KEY}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://api.jsoncargo.com/api/v1/prefix?prefix=aplu",
              "protocol": "http",
              "host": ["api", "jsoncargo", "com"],
              "path": ["api", "v1", "prefix"],
              "query": [
                {
                  "key": "prefix",
                  "value": "aplu"
                }
              ]
            },
            "description": "Look up which shipping line(s) a container prefix belongs to. Useful for determining whether shipping_line is required."
          },
          "response": []
        },
        {
